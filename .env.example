# Optional: enable live LLM calls (OpenAI-compatible chat completions).
# Without OPENAI_API_KEY, agents and the chat router use deterministic demo / keyword mode.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# SQLite path is fixed at data/ventauri.db (see api/database.py).
# Web dashboard + API runs persist there; CLI `ventauri run` persists by default too.
